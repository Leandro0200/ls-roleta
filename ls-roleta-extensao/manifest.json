{
  "manifest_version": 3,
  "name": "LS Roleta Debugger",
  "version": "1.0.0",
  "description": "Captura frames WebSocket da roleta via Chrome Debugger",
  "permissions": [
    "debugger",
    "tabs",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "LS Roleta Captura"
  }
}